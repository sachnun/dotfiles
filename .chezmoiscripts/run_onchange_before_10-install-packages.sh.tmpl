{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Packages hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
set -euo pipefail

OS_ID="{{ .chezmoi.osRelease.id }}"

install_arch_packages() {
  local packages=(
{{- range .packages.arch.pacman }}
    {{ . }}
{{- end }}
  )

  pacman -Sy --needed --noconfirm "${packages[@]}"
}

install_gh_repo() {
  if [ ! -f /etc/apt/sources.list.d/github-cli.list ]; then
    mkdir -p -m 755 /etc/apt/keyrings
    out=$(mktemp)
    wget -nv -O"$out" https://cli.github.com/packages/githubcli-archive-keyring.gpg
    cat "$out" | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | tee /etc/apt/sources.list.d/github-cli.list >/dev/null
  fi
}

install_apt_packages() {
  local packages=(
{{- if eq .chezmoi.osRelease.id "ubuntu" }}
{{- range .packages.ubuntu.apt }}
    {{ . }}
{{- end }}
{{- else if eq .chezmoi.osRelease.id "debian" }}
{{- range .packages.debian.apt }}
    {{ . }}
{{- end }}
{{- end }}
  )

  export DEBIAN_FRONTEND=noninteractive
  install_gh_repo
  apt-get update
  apt-get install -y "${packages[@]}" gh
}

case "$OS_ID" in
  arch|archlinux)
    install_arch_packages
    ;;
  ubuntu|debian)
    install_apt_packages
    ;;
  *)
    echo "Skipping package install: unsupported distro '$OS_ID'."
    ;;
esac

{{ end -}}
