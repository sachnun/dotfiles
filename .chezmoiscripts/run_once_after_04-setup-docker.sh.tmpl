{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

if [ "${CODESPACES:-false}" = "true" ]; then
  echo "Skipping Docker setup in GitHub Codespaces."
  exit 0
fi

# Install Docker packages
OS_ID="{{ .chezmoi.osRelease.id }}"

case "$OS_ID" in
  arch|archlinux)
    pacman -Sy --needed --noconfirm docker docker-compose
    ;;
  ubuntu|debian)
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y docker.io docker-compose
    ;;
  *)
    echo "Skipping Docker install: unsupported distro '$OS_ID'."
    exit 0
    ;;
esac

if ! command -v systemctl >/dev/null 2>&1 || [ ! -d /run/systemd/system ]; then
  echo "Skipping Docker setup: systemd is unavailable."
  exit 0
fi

if [ ! -f /usr/lib/systemd/system/docker.socket ] && [ ! -f /lib/systemd/system/docker.socket ] && [ ! -f /etc/systemd/system/docker.socket ]; then
  echo "Skipping Docker setup: docker.socket unit not found."
  exit 0
fi

# Enable docker socket activation (on-demand, not at startup)
# Docker daemon will only start when `docker` command is invoked
systemctl stop docker.service 2>/dev/null || true
systemctl disable docker.service 2>/dev/null || true

# containerd must remain enabled — Docker depends on it at runtime.
# Disabling it causes socket activation to fail silently.
systemctl enable containerd.service 2>/dev/null || true

# Clean up stale socket before (re)enabling
systemctl stop docker.socket 2>/dev/null || true
rm -f /var/run/docker.sock

systemctl daemon-reload
systemctl enable docker.socket
systemctl start docker.socket

# Verify socket is actually listening
if ! systemctl is-active --quiet docker.socket; then
  echo "WARNING: docker.socket failed to start. Check: journalctl -u docker.socket"
fi

# Add current user to docker group (if not root)
if [ "$(id -u)" -ne 0 ] && getent group docker >/dev/null 2>&1; then
  if command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
    sudo usermod -aG docker "$USER"
  else
    echo "Skipping docker group update: passwordless sudo unavailable."
  fi
fi
{{ end -}}
