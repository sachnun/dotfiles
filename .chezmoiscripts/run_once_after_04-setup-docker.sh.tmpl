{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

if [ "${CODESPACES:-false}" = "true" ]; then
  echo "Skipping Docker setup in GitHub Codespaces."
  exit 0
fi

if ! command -v systemctl >/dev/null 2>&1 || [ ! -d /run/systemd/system ]; then
  echo "Skipping Docker setup: systemd is unavailable."
  exit 0
fi

if [ ! -f /usr/lib/systemd/system/docker.socket ] && [ ! -f /lib/systemd/system/docker.socket ] && [ ! -f /etc/systemd/system/docker.socket ]; then
  echo "Skipping Docker setup: docker.socket unit not found."
  exit 0
fi

# Enable docker socket activation (on-demand, not at startup)
# Docker daemon will only start when `docker` command is invoked
systemctl disable docker.service 2>/dev/null || true
systemctl disable containerd.service 2>/dev/null || true
systemctl enable docker.socket
systemctl start docker.socket

# Add current user to docker group (if not root)
if [ "$(id -u)" -ne 0 ] && getent group docker >/dev/null 2>&1; then
  if command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
    sudo usermod -aG docker "$USER"
  else
    echo "Skipping docker group update: passwordless sudo unavailable."
  fi
fi
{{ end -}}
