[user]
	name = sachnun
	email = sachnun12@gmail.com


[core]
	editor = nano
	autocrlf = input
	whitespace = fix

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	default = current

[fetch]
	prune = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[rebase]
	autoStash = true

[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential

[alias]
	st = status -sb
	co = checkout
	br = branch
	cm = commit
	lg = log --oneline --graph --decorate --all
	unstage = reset HEAD --
	last = log -1 HEAD
	amend = commit --amend --no-edit

