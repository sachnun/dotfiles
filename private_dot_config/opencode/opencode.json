{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "compaction": {
    "auto": false
  },
  "command": {
    "push": {
      "template": "Categorize commit then push, dont ask.",
      "description": "Commit and push",
      "model": "github-copilot/claude-haiku-4.5",
      "subtask": true
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "baseURL": "https://copilot-stop.up.railway.app"
      },
    }
  }
}