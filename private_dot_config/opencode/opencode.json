{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "compaction": {
    "auto": false
  },
  "command": {
    "push": {
      "template": "Categorize commit, then push.",
      "description": "Commit and push"
    }
  },
  "provider": {
    "opencode": {
      "options": {
        "baseURL": "https://unroxy.koyeb.app/opencode.ai/zen/v1"
      }
    },
    "opendum": {
      "name": "Opendum",
      "options": {
        "baseURL": "https://proxy.opendum.tech/v1"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5",
          "variants": {
            "medium": {
              "reasoningEffort": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      }
    }
  }
}