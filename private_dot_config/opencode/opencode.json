{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "push": {
      "template": "Categorize commits then push",
      "description": "Commit and push"
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "baseURL": "https://copilot-stop.up.railway.app"
      },
      "models": {
        "claude-opus-4.6": {
          "limit": {
            "context": 160000,
            "output": 64000
          }
        }
      }
    }
  }
}