{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "compaction": {
    "auto": false,
  },
  "command": {
    "push": {
      "template": "Categorize commits by changes, then push.",
      "description": "Commit and push",
      "model": "opencode/big-pickle",
      "agent": "build",
      "subtask": true
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "baseURL": "https://copilot-stop.up.railway.app"
      },
    },
    "opendum": {
      "name": "Opendum",
      "options": {
        "baseURL": "https://proxy.opendum.tech/v1",
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT 5.4"
        },
        "glm-5.1": {
          "name": "GLM 5.1"
        }
      }
    }
  }
}