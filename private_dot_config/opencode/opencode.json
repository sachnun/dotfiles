{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "agent": {
    "build": {
      "color": "primary"
    },
    "plan": {
      "color": "secondary",
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "baseURL": "https://copilot-stop.up.railway.app"
      },
      "models": {
        "claude-opus-4.6": {
          "limit": {
            "context": 160000,
            "output": 64000
          }
        }
      }
    }
  }
}