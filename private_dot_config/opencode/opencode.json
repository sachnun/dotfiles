{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "compaction": {
    "auto": false,
  },
  "command": {
    "push": {
      "template": "Categorize commits by changes, then push.",
      "description": "Commit and push",
      "agent": "build",
      "subtask": true
    }
  },
  "provider": {
    "opencode": {
      "options": {
        "baseURL": "https://unroxy.koyeb.app/opencode.ai/zen/v1",
      },
    },
    "github-copilot": {
      "options": {
        "baseURL": "https://copilot-stop.up.railway.app"
      },
    },
    "opendum": {
      "name": "Opendum",
      "options": {
        "baseURL": "https://proxy.opendum.tech/v1",
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT 5.4",
          "variants": {
            "high": {
              "reasoningEffort": "high",
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
            },
          }
        },
      }
    },
  }
}